# ============================================================
# BSF-LoopTech 本番環境設定テンプレート
# Mac mini 用 -- コピーして .env.production として使用
# cp config/env.production.template .env.production
# ============================================================

# --- データベース ---
# PostgreSQL 接続 URL (asyncpg ドライバ使用)
DATABASE_URL=postgresql+asyncpg://bsf_user:CHANGE_ME@postgres:5432/bsf_system
# docker-compose.prod.yml の postgres サービスが使用する認証情報
POSTGRES_USER=bsf_user
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=bsf_system

# --- セキュリティ ---
# JWT 署名に使用する秘密鍵 (以下のコマンドで生成)
# python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=GENERATE_WITH_python3_-c_import_secrets_print_secrets_token_hex_32
# CORS 許可オリジン (カンマ区切りで複数指定可)
CORS_ORIGINS=https://bsf-looptech.local

# --- アプリケーション ---
# ログレベル: DEBUG, INFO, WARNING, ERROR (本番は WARNING 推奨)
LOG_LEVEL=WARNING
# 認証バイパス (本番では必ず false)
SKIP_AUTH=false
# ML モデル保存先 (Docker ボリューム内パス)
MODEL_REGISTRY_PATH=/app/model_registry/models

# --- LLM / RAG ---
# LLM API エンドポイント (LM Studio or ollama)
# Mac mini ホスト上で動作する LLM サーバーに Docker 内からアクセス
LLM_BASE_URL=http://host.docker.internal:1234/v1
# 使用する LLM モデル名
LLM_MODEL=openai/gpt-oss-20b
# 埋め込みモデル名 (RAG のベクトル検索用, dim=768)
EMBEDDING_MODEL=nomic-embed-text

# --- バッチ処理 ---
# APScheduler による定期ジョブの有効/無効
BATCH_ENABLED=true
# バッチジョブのタイムゾーン
BATCH_TIMEZONE=Asia/Tokyo

# --- レート制限 ---
# 1分あたりの API リクエスト上限
RATE_LIMIT_PER_MINUTE=60
