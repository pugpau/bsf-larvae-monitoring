# BSF-LoopTech Environment Configuration
# Copy this file to .env and fill in your values

# Required
DATABASE_URL=postgresql+asyncpg://bsf_user:bsf_password@localhost:5432/bsf_system
SECRET_KEY=<generate-a-random-key>

# Optional (defaults shown)
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
SKIP_AUTH=false
MODEL_REGISTRY_PATH=model_registry/models

# PostgreSQL (alternative to DATABASE_URL)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=bsf_user
POSTGRES_PASSWORD=bsf_password
POSTGRES_DB=bsf_system
